            for j = 0, 3 do
                local b = frame:FindFirstChild(levels[j+1].."Btn")
                if b then b.BackgroundColor3 = (i == j) and Color3.fromRGB(0,200,100) or colors[j+1] end
            end
        end)
        btn.Name = levels[i+1].."Btn"
    end
end

