-- ============================================
-- LOCALSCRIPT HOÀN CHỈNH - FIX LAG + HIỆN SỐ BALO (ĐÃ SỬA KHÔNG ẨN GUI)
-- Vị trí: StarterPlayer → StarterPlayerScripts
-- ============================================

local Players = game:GetService("Players")
local Workspace = game.Workspace
local Lighting = game.Lighting
local RunService = game:GetService("RunService")
local Camera = Workspace.CurrentCamera

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ============================================
-- CÀI ĐẶT MẶC ĐỊNH (TẤT CẢ OFF)
-- ============================================
local Settings = {
	MasterEnabled = false,
	Fullbright = false,
	ExtremeLowGraphics = false,
	MuteAllSounds = false,
	FOVCulling = false,
	PerformanceMode = false,
	CleanDebris = false,
	MAX_VISIBLE = 12,
	MAX_DISTANCE = 300,
	FOV_ANGLE = 120
}

local graphicsApplied = false
local extremeGraphicsApplied = false
local allSoundsMuted = false

-- ============================================
-- CACHE ZOMBIE (QUÉT MỖI 5 GIÂY)
-- ============================================
local zombieCache = {}
local lastZombieScan = 0
local ZOMBIE_SCAN_INTERVAL = 5

local function scanZombies()
	local now = os.clock()
	if now - lastZombieScan < ZOMBIE_SCAN_INTERVAL then
		return zombieCache
	end
	lastZombieScan = now

	table.clear(zombieCache)

	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Model") 
			and obj:FindFirstChild("Humanoid") 
			and obj:FindFirstChild("HumanoidRootPart") 
			and not Players:GetPlayerFromCharacter(obj) then
			zombieCache[#zombieCache + 1] = obj
		end
	end

	for _, folder in pairs(Workspace:GetChildren()) do
		if folder:IsA("Folder") or folder:IsA("Model") then
			for _, obj in pairs(folder:GetChildren()) do
				if obj:IsA("Model") 
					and obj:FindFirstChild("Humanoid") 
					and obj:FindFirstChild("HumanoidRootPart") 
					and not Players:GetPlayerFromCharacter(obj) then
					zombieCache[#zombieCache + 1] = obj
				end
			end
		end
	end

	return zombieCache
end

-- ============================================
-- 1. FULLBRIGHT
-- ============================================
local function enableFullbright()
	Lighting.Brightness = 3
	Lighting.ClockTime = 14
	Lighting.FogEnd = 99999
	Lighting.GlobalShadows = false
	Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
	Lighting.Ambient = Color3.fromRGB(255, 255, 255)
	Lighting.EnvironmentDiffuseScale = 1
	Lighting.EnvironmentSpecularScale = 0
	pcall(function()
		if Lighting:FindFirstChildOfClass("BloomEffect") then Lighting:FindFirstChildOfClass("BloomEffect").Enabled = false end
		if Lighting:FindFirstChildOfClass("BlurEffect") then Lighting:FindFirstChildOfClass("BlurEffect").Enabled = false end
		if Lighting:FindFirstChildOfClass("ColorCorrectionEffect") then Lighting:FindFirstChildOfClass("ColorCorrectionEffect").Enabled = false end
	end)
end

local function disableFullbright()
	Lighting.Brightness = 1.1
	Lighting.FogEnd = 200
	Lighting.OutdoorAmbient = Color3.fromRGB(60, 60, 60)
	Lighting.Ambient = Color3.fromRGB(80, 80, 80)
	Lighting.EnvironmentDiffuseScale = 0.2
end

-- ============================================
-- 2. EXTREME LOW GRAPHICS (ĐÃ SỬA: KHÔNG TẮT SURFACEGUI/BILLBOARDGUI)
-- ============================================
local function applyExtremeLowGraphics()
	if extremeGraphicsApplied then return end
	extremeGraphicsApplied = true

	Lighting.GlobalShadows = false
	Lighting.Outlines = false
	Lighting.EnvironmentDiffuseScale = 0
	Lighting.EnvironmentSpecularScale = 0
	Lighting.FogEnd = 50
	Lighting.FogStart = 0
	Lighting.Brightness = 1

	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function()
			if obj:IsA("BasePart") then
				obj.CastShadow = false
				obj.Reflectance = 0
				obj.Material = Enum.Material.SmoothPlastic
			elseif obj:IsA("Texture") or obj:IsA("Decal") then
				-- Chỉ xoá texture/decal trên bề mặt, không đụng vào GUI
				if not obj:IsDescendantOf(playerGui) then
					obj:Destroy()
				end
			elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
				obj.Enabled = false
			-- KHÔNG tắt SurfaceGui, BillboardGui nữa
			end
		end)
	end

	pcall(function()
		Workspace.Terrain.Decoration = false
		Workspace.Terrain.WaterWaveSize = 0
		Workspace.Terrain.WaterWaveSpeed = 0
		Workspace.Terrain.WaterReflectance = 0
		Workspace.Terrain.WaterTransparency = 1
	end)

	pcall(function()
		Workspace.StreamingEnabled = true
		Workspace.StreamingMinRadius = 0
		Workspace.StreamingTargetRadius = 50
	end)

	print("✅ Extreme Low Graphics đã bật (giữ nguyên GUI)!")
end

Workspace.DescendantAdded:Connect(function(obj)
	if not extremeGraphicsApplied then return end
	pcall(function()
		if obj:IsA("BasePart") then
			obj.CastShadow = false
			obj.Reflectance = 0
			obj.Material = Enum.Material.SmoothPlastic
		elseif obj:IsA("Texture") or obj:IsA("Decal") then
			if not obj:IsDescendantOf(playerGui) then
				obj:Destroy()
			end
		elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
			obj.Enabled = false
		-- Không đụng vào SurfaceGui, BillboardGui
		end
	end)
end)

-- ============================================
-- 3. NÚT TẮT TOÀN BỘ ÂM THANH (RIÊNG)
-- ============================================
local function toggleMuteAllSounds(enabled)
	allSoundsMuted = enabled
	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function()
			if obj:IsA("Sound") then
				obj.Volume = enabled and 0 or 1
			end
		end)
	end
end

Workspace.DescendantAdded:Connect(function(obj)
	if not allSoundsMuted then return end
	pcall(function()
		if obj:IsA("Sound") then
			obj.Volume = 0
		end
	end)
end)

-- ============================================
-- 4. GIẢM CHẤT LƯỢNG ZOMBIE
-- ============================================
local processedZombies = {}
local function applyLowQuality(zombie)
	if not Settings.PerformanceMode then return end
	if processedZombies[zombie] then return end
	processedZombies[zombie] = true

	for _, part in pairs(zombie:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CastShadow = false
			part.Material = Enum.Material.SmoothPlastic
		end
	end
end

-- ============================================
-- 5. FOV CULLING
-- ============================================
local function optimizeZombies()
	if not Settings.MasterEnabled or not Settings.FOVCulling then
		for _, zombie in ipairs(zombieCache) do
			pcall(function()
				for _, part in pairs(zombie:GetDescendants()) do
					if part:IsA("BasePart") and part.Transparency == 1 then
						part.Transparency = 0
					end
				end
				local humanoid = zombie:FindFirstChildOfClass("Humanoid")
				if humanoid then
					local animator = humanoid:FindFirstChildOfClass("Animator")
					if animator then animator:Resume() end
				end
			end)
		end
		return
	end

	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local playerPos = root.Position

	if not Camera then Camera = Workspace.CurrentCamera end
	if not Camera then return end
	local camPos = Camera.CFrame.Position
	local camLook = Camera.CFrame.LookVector

	local zombies = scanZombies()
	local zombieData = {}

	for _, zombie in ipairs(zombies) do
		local hrp = zombie:FindFirstChild("HumanoidRootPart")
		if hrp then
			local dist = (hrp.Position - playerPos).Magnitude
			if dist <= Settings.MAX_DISTANCE then
				local dirToZombie = (hrp.Position - camPos).Unit
				local dot = camLook:Dot(dirToZombie)
				local angle = math.deg(math.acos(dot))
				zombieData[#zombieData + 1] = {
					zombie = zombie,
					distance = dist,
					angle = angle,
					inFOV = angle <= (Settings.FOV_ANGLE / 2)
				}
			end
		end
	end

	table.sort(zombieData, function(a, b)
		if a.inFOV ~= b.inFOV then return a.inFOV end
		return a.distance < b.distance
	end)

	local visibleCount = 0
	for _, data in ipairs(zombieData) do
		local shouldShow = (visibleCount < Settings.MAX_VISIBLE) and data.inFOV
		local zombie = data.zombie

		pcall(function()
			if shouldShow then applyLowQuality(zombie) end
			
			local targetTrans = shouldShow and 0 or 1
			for _, part in pairs(zombie:GetDescendants()) do
				if part:IsA("BasePart") and part.Transparency ~= targetTrans then
					part.Transparency = targetTrans
				end
			end

			local humanoid = zombie:FindFirstChildOfClass("Humanoid")
			if humanoid then
				local animator = humanoid:FindFirstChildOfClass("Animator")
				if animator then
					if shouldShow then animator:Resume() else animator:Step(0) end
				end
			end
		end)

		if shouldShow then visibleCount += 1 end
	end
end

-- ============================================
-- 6. DỌN RÁC
-- ============================================
local function cleanDebris()
	if not Settings.MasterEnabled or not Settings.CleanDebris then return end
	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function()
			if obj:IsA("BasePart") then
				local name = obj.Name:lower()
				if name:find("blood") or name:find("shell") or name:find("gore") or name:find("debris") then
					obj:Destroy()
				end
			end
		end)
	end
end

-- ============================================
-- 7. VÒNG LẶP CHÍNH
-- ============================================
task.spawn(function()
	while true do
		if Settings.MasterEnabled then
			pcall(optimizeZombies)
		end
		task.wait(0.5)
	end
end)

task.spawn(function()
	while true do
		pcall(cleanDebris)
		task.wait(20)
	end
end)

-- ============================================
-- 8. GUI: MENU TIẾNG VIỆT + HIỆN SỐ BALO
-- ============================================
local function createGUI()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = "FixLagMenu"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = playerGui

	-- FPS to rõ
	local fpsFrame = Instance.new("Frame")
	fpsFrame.Size = UDim2.new(0, 140, 0, 40)
	fpsFrame.Position = UDim2.new(1, -150, 1, -50)
	fpsFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	fpsFrame.BackgroundTransparency = 0.5
	fpsFrame.BorderSizePixel = 0
	fpsFrame.Parent = screenGui

	Instance.new("UICorner", fpsFrame).CornerRadius = UDim.new(0, 6)
	local stroke = Instance.new("UIStroke", fpsFrame)
	stroke.Thickness = 1
	stroke.Color = Color3.fromRGB(0, 255, 0)
	stroke.Transparency = 0.5

	local fpsLabel = Instance.new("TextLabel")
	fpsLabel.Size = UDim2.new(1, 0, 1, 0)
	fpsLabel.BackgroundTransparency = 1
	fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
	fpsLabel.Font = Enum.Font.SourceSansBold
	fpsLabel.TextSize = 22
	fpsLabel.Text = "FPS: --"
	fpsLabel.Parent = fpsFrame

	-- Menu chính
	local mainFrame = Instance.new("Frame")
	mainFrame.Size = UDim2.new(0, 230, 0, 380)
	mainFrame.Position = UDim2.new(1, -240, 0, 10)
	mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	mainFrame.BorderSizePixel = 0
	mainFrame.Active = true
	mainFrame.Draggable = true
	mainFrame.Parent = screenGui

	local titleBar = Instance.new("Frame")
	titleBar.Size = UDim2.new(1, 0, 0, 30)
	titleBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	titleBar.BorderSizePixel = 0
	titleBar.Parent = mainFrame

	local titleText = Instance.new("TextLabel")
	titleText.Size = UDim2.new(1, -30, 1, 0)
	titleText.Position = UDim2.new(0, 5, 0, 0)
	titleText.BackgroundTransparency = 1
	titleText.Text = "FIX LAG (TẮT)"
	titleText.TextColor3 = Color3.fromRGB(255, 255, 255)
	titleText.Font = Enum.Font.SourceSansBold
	titleText.TextSize = 16
	titleText.Parent = titleBar

	local collapseBtn = Instance.new("TextButton")
	collapseBtn.Size = UDim2.new(0, 30, 0, 30)
	collapseBtn.Position = UDim2.new(1, -30, 0, 0)
	collapseBtn.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
	collapseBtn.Text = "—"
	collapseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
	collapseBtn.Font = Enum.Font.SourceSansBold
	collapseBtn.TextSize = 18
	collapseBtn.Parent = titleBar

	local contentFrame = Instance.new("Frame")
	contentFrame.Size = UDim2.new(1, -10, 1, -35)
	contentFrame.Position = UDim2.new(0, 5, 0, 35)
	contentFrame.BackgroundTransparency = 1
	contentFrame.Parent = mainFrame

	local scrollFrame = Instance.new("ScrollingFrame")
	scrollFrame.Size = UDim2.new(1, 0, 1, 0)
	scrollFrame.CanvasSize = UDim2.new(0, 0, 2, 0)
	scrollFrame.ScrollBarThickness = 4
	scrollFrame.BackgroundTransparency = 1
	scrollFrame.Parent = contentFrame

	local yOffset = 0
	local function createToggle(text, settingName, callback)
		local frame = Instance.new("Frame")
		frame.Size = UDim2.new(1, 0, 0, 25)
		frame.Position = UDim2.new(0, 0, 0, yOffset)
		frame.BackgroundTransparency = 1
		frame.Parent = scrollFrame

		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(0.6, -5, 1, 0)
		label.BackgroundTransparency = 1
		label.Text = text
		label.TextColor3 = Color3.fromRGB(255, 255, 255)
		label.Font = Enum.Font.SourceSans
		label.TextSize = 13
		label.TextXAlignment = Enum.TextXAlignment.Left
		label.Parent = frame

		local isOn = Settings[settingName]
		local toggle = Instance.new("TextButton")
		toggle.Size = UDim2.new(0.4, -5, 1, 0)
		toggle.Position = UDim2.new(0.6, 5, 0, 0)
		toggle.BackgroundColor3 = isOn and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
		toggle.Text = isOn and "BẬT" or "TẮT"
		toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
		toggle.Font = Enum.Font.SourceSansBold
		toggle.TextSize = 13
		toggle.Parent = frame

		toggle.MouseButton1Click:Connect(function()
			Settings[settingName] = not Settings[settingName]
			local on = Settings[settingName]
			toggle.BackgroundColor3 = on and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
			toggle.Text = on and "BẬT" or "TẮT"
			
			if callback then callback(on) end
		end)

		yOffset += 28
		scrollFrame.CanvasSize = UDim2.new(0, 0, 0, yOffset)
		return toggle
	end

	createToggle("Công tắc chính", "MasterEnabled", function(on)
		titleText.Text = on and "FIX LAG (BẬT)" or "FIX LAG (TẮT)"
	end)
	createToggle("Fullbright (Sáng)", "Fullbright", function(on)
		if on then enableFullbright() else disableFullbright() end
	end)
	createToggle("Giảm đồ họa siêu mạnh", "ExtremeLowGraphics", function(on)
		if on then applyExtremeLowGraphics() end
	end)
	createToggle("Tắt toàn bộ âm thanh", "MuteAllSounds", toggleMuteAllSounds)
	createToggle("FOV Culling (Ẩn zombie)", "FOVCulling")
	createToggle("Giảm chất lượng zombie", "PerformanceMode")
	createToggle("Dọn rác (máu, vỏ đạn)", "CleanDebris")

	-- Thu gọn menu
	local collapsed = false
	collapseBtn.MouseButton1Click:Connect(function()
		collapsed = not collapsed
		contentFrame.Visible = not collapsed
		mainFrame.Size = collapsed and UDim2.new(0, 230, 0, 35) or UDim2.new(0, 230, 0, 380)
		collapseBtn.Text = collapsed and "+" or "—"
	end)

	-- FPS counter
	local lastTime = os.clock()
	local frameCount = 0
	RunService.Heartbeat:Connect(function()
		frameCount += 1
		local now = os.clock()
		if now - lastTime >= 0.5 then
			local fps = math.floor(frameCount / (now - lastTime))
			fpsLabel.Text = "FPS: " .. fps
			if fps >= 50 then
				fpsLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
			elseif fps >= 25 then
				fpsLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
			else
				fpsLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
			end
			frameCount = 0
			lastTime = now
		end
	end)

	-- ============================================
	-- 9. HIỆN LẠI SỐ BALO (TÍCH HỢP)
	-- ============================================
	for _, obj in pairs(playerGui:GetDescendants()) do
		if obj:IsA("TextLabel") then
			obj.Visible = true
		end
	end

	playerGui.DescendantAdded:Connect(function(descendant)
		if descendant:IsA("TextLabel") then
			descendant.Visible = true
		end
		descendant:GetPropertyChangedSignal("Visible"):Connect(function()
			if descendant:IsA("TextLabel") and not descendant.Visible then
				descendant.Visible = true
			end
		end)
	end)

	print("✅ Số balo đã hiện trở lại!")
end

createGUI()

print("✅ Script tổng hợp đã chạy - Balo hiện số, không tắt GUI, giảm đồ hoạ an toàn!")
