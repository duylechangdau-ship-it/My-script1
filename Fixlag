		btn.Text = levels[i + 1] btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		btn.Font = Enum.Font.SourceSansBold btn.TextSize = 12 btn.BorderSizePixel = 0
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
		btn.MouseButton1Click:Connect(function()
			settings.WallTransparency = i
			applyWallTransparency(i)
			for j = 0, 3 do
				local b = frame:FindFirstChild(levels[j + 1].."Btn")
				if b then b.BackgroundColor3 = (i == j) and Color3.fromRGB(0, 200, 100) or colors[j + 1] end
			end
		end)
		btn.Name = levels[i + 1].."Btn"
	end
end

