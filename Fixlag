-- ============================================
-- FPS COUNTER
-- ============================================
local lt, fc = os.clock(), 0
game:GetService("RunService").Heartbeat:Connect(function()
	fc += 1; local n = os.clock()
	if n - lt >= 0.5 then
		local fps = math.floor(fc/(n-lt))
		fpsL.Text = "FPS: " .. fps
		if fps >= 30 then fpsL.TextColor3 = Color3.fromRGB(0,255,150)
		elseif fps >= 15 then fpsL.TextColor3 = Color3.fromRGB(255,255,0)
		else fpsL.TextColor3 = Color3.fromRGB(255,80,80) end
		fc, lt = 0, n
	end
end)

