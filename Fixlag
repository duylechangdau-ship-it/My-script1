local function createToggle(parent, yRef, text, setting, cb)
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1,0,0,25) frame.Position = UDim2.new(0,0,0,yRef[1])
	frame.BackgroundTransparency = 1 frame.Parent = parent
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.65,-5,1,0) label.BackgroundTransparency = 1 label.Text = text
	label.TextColor3 = Color3.fromRGB(255,255,255) label.Font = Enum.Font.SourceSans label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left label.Parent = frame
	local isOn = settings[setting]
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0.35,-5,1,0) btn.Position = UDim2.new(0.65,5,0,0)
	btn.BackgroundColor3 = isOn and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
	btn.Text = isOn and "BẬT" or "TẮT"
	btn.TextColor3 = Color3.fromRGB(255,255,255) btn.Font = Enum.Font.SourceSansBold btn.TextSize = 13 btn.Parent = frame
	btn.MouseButton1Click:Connect(function()
		settings[setting] = not settings[setting]
		local on = settings[setting]
		btn.BackgroundColor3 = on and Color3.fromRGB(0,170,0) or Color3.fromRGB(170,0,0)
		btn.Text = on and "BẬT" or "TẮT"
		if setting == "MasterEnabled" then titleText.Text = on and "FIX LAG (BẬT)" or "FIX LAG (TẮT)" end
		if cb then cb(on) end
	end)
	yRef[1] += 28
	return btn
end

local function createTextBox(parent, yRef, text, setting, min, max)
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(1,0,0,30) frame.Position = UDim2.new(0,0,0,yRef[1])
	frame.BackgroundTransparency = 1 frame.Parent = parent
	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0.6,-5,1,0) label.BackgroundTransparency = 1 label.Text = text
	label.TextColor3 = Color3.fromRGB(255,255,255) label.Font = Enum.Font.SourceSans label.TextSize = 13
	label.TextXAlignment = Enum.TextXAlignment.Left label.Parent = frame
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0.4,-5,0,25) box.Position = UDim2.new(0.6,5,0,0)
	box.BackgroundColor3 = Color3.fromRGB(50,50,50) box.TextColor3 = Color3.fromRGB(255,255,255)
	box.Font = Enum.Font.SourceSans box.TextSize = 13 box.Text = tostring(settings[setting]) box.Parent = frame
	box.FocusLost:Connect(function()
		local num = tonumber(box.Text)
		if num and num >= min and num <= max then settings[setting] = num; notify("✅ Đã cập nhật "..text.." = "..num)
		else box.Text = tostring(settings[setting]); notify("⚠️ Giá trị không hợp lệ ("..min.."-"..max..")", 2.5) end
	end)
	yRef[1] += 32
	return box
end

