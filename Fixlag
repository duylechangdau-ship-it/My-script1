	lbl.BackgroundColor3 = Color3.fromRGB(0,0,0) lbl.BackgroundTransparency = 0.6
	lbl.TextColor3 = Color3.fromRGB(255,255,255) lbl.Text = message
	lbl.Font = Enum.Font.SourceSansBold lbl.TextSize = 16 lbl.Parent = gui
	Instance.new("UICorner", lbl).CornerRadius = UDim.new(0,6)
	local s = Instance.new("UIStroke", lbl) s.Thickness = 1 s.Color = Color3.fromRGB(0,255,0) s.Transparency = 0.3
