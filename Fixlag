-- FixLag Core - THÊM XÓA LIGHT (AN TOÀN VỚI FULLBRIGHT)
local Players = game:GetService("Players")
local Workspace = game.Workspace
local Lighting = game.Lighting
local RunService = game:GetService("RunService")
local Camera = Workspace.CurrentCamera
local player = Players.LocalPlayer

local Settings = {
	MasterEnabled = false,
	Fullbright = false,
	ExtremeLowGraphics = false,
	MuteAllSounds = false,
	DisableSky = false,
	FOVCulling = false,
	PerformanceMode = false,
	CleanDebris = false,
	HidePlayers = false,
	MAX_VISIBLE = 12,
	MAX_DISTANCE = 300,
	FOV_ANGLE = 120
}

local extremeGraphicsApplied = false
local allSoundsMuted = false
local skyDisabled = false
local zombieCache = {}
local lastZombieScan = 0
local ZOMBIE_SCAN_INTERVAL = 5
local processedZombies = {}

local function scanZombies()
	local now = os.clock()
	if now - lastZombieScan < ZOMBIE_SCAN_INTERVAL then return zombieCache end
	lastZombieScan = now
	table.clear(zombieCache)
	for _, obj in pairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and not Players:GetPlayerFromCharacter(obj) then
			zombieCache[#zombieCache + 1] = obj
		end
	end
	return zombieCache
end

local function enableFullbright()
	Lighting.Brightness, Lighting.ClockTime, Lighting.FogEnd = 3, 14, 99999
	Lighting.GlobalShadows, Lighting.OutdoorAmbient, Lighting.Ambient = false, Color3.fromRGB(255,255,255), Color3.fromRGB(255,255,255)
	Lighting.EnvironmentDiffuseScale, Lighting.EnvironmentSpecularScale = 1, 0
	pcall(function()
		if Lighting:FindFirstChildOfClass("BloomEffect") then Lighting:FindFirstChildOfClass("BloomEffect").Enabled = false end
		if Lighting:FindFirstChildOfClass("BlurEffect") then Lighting:FindFirstChildOfClass("BlurEffect").Enabled = false end
		if Lighting:FindFirstChildOfClass("ColorCorrectionEffect") then Lighting:FindFirstChildOfClass("ColorCorrectionEffect").Enabled = false end
	end)
end

local function disableFullbright()
	Lighting.Brightness, Lighting.FogEnd = 1.1, 200
	Lighting.OutdoorAmbient, Lighting.Ambient = Color3.fromRGB(60,60,60), Color3.fromRGB(80,80,80)
	Lighting.EnvironmentDiffuseScale = 0.2
end

local function disableSky(enabled)
	skyDisabled = enabled
	if enabled then
		for _, obj in pairs(Lighting:GetChildren()) do
			if obj:IsA("Sky") or obj:IsA("Atmosphere") or obj:IsA("SunRaysEffect") or obj:IsA("Clouds") then obj:Destroy() end
		end
	end
end

-- Kiểm tra accessory
local function isAccessory(part)
	local parent = part.Parent
	while parent do
		if parent:IsA("Accoutrement") or parent.Name == "Accessory" or parent.Name:find("Handle") then
			return true
		end
		parent = parent.Parent
	end
	return false
end

-- Extreme Low Graphics - ĐÃ THÊM XÓA LIGHT
local function applyExtremeLowGraphics()
	if extremeGraphicsApplied then return end
	extremeGraphicsApplied = true
	Lighting.GlobalShadows, Lighting.Outlines = false, false
	Lighting.EnvironmentDiffuseScale, Lighting.EnvironmentSpecularScale = 0, 0
	Lighting.FogEnd, Lighting.FogStart, Lighting.Brightness = 50, 0, 1
	
	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function()
			if obj:IsA("BasePart") and not isAccessory(obj) then
				obj.CastShadow, obj.Reflectance = false, 0
				if obj.Material ~= Enum.Material.Plastic then
					obj.Material = Enum.Material.SmoothPlastic
				end
			elseif obj:IsA("Texture") or obj:IsA("Decal") then
				if not obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then obj:Destroy() end
			elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") 
				or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") 
				or obj:IsA("Explosion") then
				obj:Destroy()
			-- THÊM XÓA LIGHT
			elseif obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
				obj:Destroy()
			end
		end)
	end
	
	pcall(function()
		Workspace.Terrain.Decoration = false
		Workspace.Terrain.WaterWaveSize, Workspace.Terrain.WaterWaveSpeed = 0, 0
		Workspace.Terrain.WaterReflectance, Workspace.Terrain.WaterTransparency = 0, 1
	end)
end

-- Bắt vật thể mới spawn
Workspace.DescendantAdded:Connect(function(obj)
	if not extremeGraphicsApplied then return end
	pcall(function()
		if obj:IsA("BasePart") and not isAccessory(obj) then
			obj.CastShadow, obj.Reflectance = false, 0
			if obj.Material ~= Enum.Material.Plastic then obj.Material = Enum.Material.SmoothPlastic end
		elseif (obj:IsA("Texture") or obj:IsA("Decal")) and not obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then
			obj:Destroy()
		elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") 
