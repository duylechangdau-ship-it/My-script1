local function createToggle(parent, y, text, setting, cb)
	local f = Instance.new("Frame", parent)
	f.Size = UDim2.new(1,-12,0,42) f.Position = UDim2.new(0,6,0,y[1])
	f.BackgroundColor3 = Color3.fromRGB(80,80,90) -- MÀU NỀN TOGGLE SÁNG
	f.BackgroundTransparency = 0.1 f.BorderSizePixel = 0
	Instance.new("UICorner", f).CornerRadius = UDim.new(0,10)
	
	local lbl = Instance.new("TextLabel", f)
	lbl.Size = UDim2.new(0.52,-6,1,0) lbl.Position = UDim2.new(0,6,0,0)
	lbl.BackgroundTransparency = 1 lbl.Text = text
	lbl.TextColor3 = Color3.fromRGB(255,255,255) lbl.Font = Enum.Font.SourceSansBold lbl.TextSize = 14
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	
	local isOn = settings[setting]
	local btn = Instance.new("TextButton", f)
	btn.Size = UDim2.new(0.48,-6,0,34) btn.Position = UDim2.new(0.52,3,0,4)
	btn.BackgroundColor3 = isOn and Color3.fromRGB(0,200,100) or Color3.fromRGB(200,50,50)
	btn.Text = isOn and "✅ BẬT" or "❌ TẮT"
	btn.TextColor3 = Color3.fromRGB(255,255,255) btn.Font = Enum.Font.SourceSansBold btn.TextSize = 14
	btn.BorderSizePixel = 0
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)
	
	btn.MouseButton1Click:Connect(function()
		settings[setting] = not settings[setting]
		local on = settings[setting]
		btn.BackgroundColor3 = on and Color3.fromRGB(0,200,100) or Color3.fromRGB(200,50,50)
		btn.Text = on and "✅ BẬT" or "❌ TẮT"
		if setting == "MasterEnabled" then
			titleText.Text = on and "⚡ FIX LAG PRO (ON)" or "⚡ FIX LAG PRO (OFF)"
			iconBtn.BackgroundColor3 = on and Color3.fromRGB(0,200,80) or Color3.fromRGB(255,80,80)
		end
		if cb then cb(on) end
		saveSettings()
	end)
	y[1] += 50
end

