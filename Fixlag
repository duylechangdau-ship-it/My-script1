-- FixLag Core (xử lý zombie, fullbright, đồ họa, âm thanh)
local Players = game:GetService("Players")
local Workspace = game.Workspace
local Lighting = game.Lighting
local RunService = game:GetService("RunService")
local Camera = Workspace.CurrentCamera
local player = Players.LocalPlayer

local Settings = {
	MasterEnabled = false, Fullbright = false, ExtremeLowGraphics = false,
	MuteAllSounds = false, DisableSky = false, FOVCulling = false,
	PerformanceMode = false, CleanDebris = false,
	MAX_VISIBLE = 12, MAX_DISTANCE = 300, FOV_ANGLE = 120
}

local extremeGraphicsApplied, allSoundsMuted, skyDisabled, graphicsApplied = false, false, false, false
local zombieCache, lastZombieScan, ZOMBIE_SCAN_INTERVAL = {}, 0, 5
local processedZombies = {}

local function scanZombies()
	local now = os.clock()
	if now - lastZombieScan < ZOMBIE_SCAN_INTERVAL then return zombieCache end
	lastZombieScan = now
	table.clear(zombieCache)
	for _, obj in pairs(Workspace:GetChildren()) do
		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and not Players:GetPlayerFromCharacter(obj) then
			zombieCache[#zombieCache+1] = obj
		end
	end
	for _, folder in pairs(Workspace:GetChildren()) do
		if folder:IsA("Folder") or folder:IsA("Model") then
			for _, obj in pairs(folder:GetChildren()) do
				if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") and not Players:GetPlayerFromCharacter(obj) then
					zombieCache[#zombieCache+1] = obj
				end
			end
		end
	end
	return zombieCache
end

local function enableFullbright()
	Lighting.Brightness, Lighting.ClockTime, Lighting.FogEnd = 3, 14, 99999
	Lighting.GlobalShadows, Lighting.OutdoorAmbient, Lighting.Ambient = false, Color3.fromRGB(255,255,255), Color3.fromRGB(255,255,255)
	Lighting.EnvironmentDiffuseScale, Lighting.EnvironmentSpecularScale = 1, 0
	pcall(function()
		if Lighting:FindFirstChildOfClass("BloomEffect") then Lighting:FindFirstChildOfClass("BloomEffect").Enabled = false end
		if Lighting:FindFirstChildOfClass("BlurEffect") then Lighting:FindFirstChildOfClass("BlurEffect").Enabled = false end
		if Lighting:FindFirstChildOfClass("ColorCorrectionEffect") then Lighting:FindFirstChildOfClass("ColorCorrectionEffect").Enabled = false end
	end)
end

local function disableFullbright()
	Lighting.Brightness, Lighting.FogEnd = 1.1, 200
	Lighting.OutdoorAmbient, Lighting.Ambient = Color3.fromRGB(60,60,60), Color3.fromRGB(80,80,80)
	Lighting.EnvironmentDiffuseScale = 0.2
end

local function disableSky(enabled)
	skyDisabled = enabled
	if enabled then
		for _, obj in pairs(Lighting:GetChildren()) do
			if obj:IsA("Sky") or obj:IsA("Atmosphere") or obj:IsA("SunRaysEffect") or obj:IsA("Clouds") then obj:Destroy() end
		end
	end
end

local function applyExtremeLowGraphics()
	if extremeGraphicsApplied then return end
	extremeGraphicsApplied = true
	Lighting.GlobalShadows, Lighting.Outlines = false, false
	Lighting.EnvironmentDiffuseScale, Lighting.EnvironmentSpecularScale = 0, 0
	Lighting.FogEnd, Lighting.FogStart, Lighting.Brightness = 50, 0, 1
	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function()
			if obj:IsA("BasePart") then
				obj.CastShadow, obj.Reflectance = false, 0
				obj.Material = Enum.Material.SmoothPlastic
			elseif obj:IsA("Texture") or obj:IsA("Decal") then
				if not obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then obj:Destroy() end
			elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
				obj.Enabled = false
			end
		end)
	end
	pcall(function()
		Workspace.Terrain.Decoration = false
		Workspace.Terrain.WaterWaveSize, Workspace.Terrain.WaterWaveSpeed = 0, 0
		Workspace.Terrain.WaterReflectance, Workspace.Terrain.WaterTransparency = 0, 1
	end)
	pcall(function() Workspace.StreamingEnabled = true; Workspace.StreamingMinRadius = 0; Workspace.StreamingTargetRadius = 50 end)
end

Workspace.DescendantAdded:Connect(function(obj)
	if not extremeGraphicsApplied then return end
	pcall(function()
		if obj:IsA("BasePart") then obj.CastShadow, obj.Reflectance = false, 0; obj.Material = Enum.Material.SmoothPlastic
		elseif (obj:IsA("Texture") or obj:IsA("Decal")) and not obj:IsDescendantOf(player:WaitForChild("PlayerGui")) then obj:Destroy()
		elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then obj.Enabled = false
		end
	end)
end)

local function toggleMuteAllSounds(enabled)
	allSoundsMuted = enabled
	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function() if obj:IsA("Sound") then obj.Volume = enabled and 0 or 1 end end)
	end
end
Workspace.DescendantAdded:Connect(function(obj)
	if not allSoundsMuted then return end
	pcall(function() if obj:IsA("Sound") then obj.Volume = 0 end end)
end)

local function applyLowQuality(zombie)
	if not Settings.PerformanceMode or processedZombies[zombie] then return end
	processedZombies[zombie] = true
	for _, part in pairs(zombie:GetDescendants()) do
		if part:IsA("BasePart") then part.CastShadow = false; part.Material = Enum.Material.SmoothPlastic end
	end
end

local function optimizeZombies()
	if not Settings.MasterEnabled or not Settings.FOVCulling then
		for _, zombie in ipairs(zombieCache) do
			pcall(function()
				for _, part in pairs(zombie:GetDescendants()) do
					if part:IsA("BasePart") and part.Transparency == 1 then part.Transparency = 0 end
				end
				local h = zombie:FindFirstChildOfClass("Humanoid")
				if h then local a = h:FindFirstChildOfClass("Animator") if a then a:Resume() end end
			end)
		end
		return
	end
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	local playerPos = root.Position
	if not Camera then Camera = Workspace.CurrentCamera end
	if not Camera then return end
	local camPos, camLook = Camera.CFrame.Position, Camera.CFrame.LookVector
	local zombies = scanZombies()
	local zombieData = {}
	for _, zombie in ipairs(zombies) do
		local hrp = zombie:FindFirstChild("HumanoidRootPart")
		if hrp then
			local dist = (hrp.Position - playerPos).Magnitude
			if dist <= Settings.MAX_DISTANCE then
				local dir = (hrp.Position - camPos).Unit
				local dot = camLook:Dot(dir)
				local angle = math.deg(math.acos(dot))
				zombieData[#zombieData+1] = {zombie = zombie, distance = dist, angle = angle, inFOV = angle <= (Settings.FOV_ANGLE/2)}
			end
		end
	end
	table.sort(zombieData, function(a,b) if a.inFOV ~= b.inFOV then return a.inFOV else return a.distance < b.distance end end)
	local visibleCount = 0
	for _, data in ipairs(zombieData) do
		local show = (visibleCount < Settings.MAX_VISIBLE) and data.inFOV
		local zombie = data.zombie
		pcall(function()
			if show then applyLowQuality(zombie) end
			local targetTrans = show and 0 or 1
			for _, part in pairs(zombie:GetDescendants()) do
				if part:IsA("BasePart") and part.Transparency ~= targetTrans then part.Transparency = targetTrans end
			end
			local h = zombie:FindFirstChildOfClass("Humanoid")
			if h then local a = h:FindFirstChildOfClass("Animator") if a then if show then a:Resume() else a:Step(0) end end end
		end)
		if show then visibleCount += 1 end
	end
end

local function cleanDebris()
	if not Settings.MasterEnabled or not Settings.CleanDebris then return end
	for _, obj in pairs(Workspace:GetDescendants()) do
		pcall(function()
			if obj:IsA("BasePart") then
				local n = obj.Name:lower()
				if n:find("blood") or n:find("shell") or n:find("gore") or n:find("debris") then obj:Destroy() end
			end
		end)
	end
end

task.spawn(function() while true do if Settings.MasterEnabled then pcall(optimizeZombies) end task.wait(0.5) end end)
task.spawn(function() while true do pcall(cleanDebris) task.wait(20) end end)

