local function isCharacterPart(part)
    local current = part
    while current and current ~= workspace do
        local parent = current.Parent
        if parent and parent:IsA("Model") then
            if parent:FindFirstChild("HumanoidRootPart") then
                return true
            end
        end
        current = parent
    end
    return false
end

local function applyWallTransparency(level)
    for _, p in ipairs(wallParts) do
        pcall(function() p.Transparency = 0 end)
    end
    table.clear(wallParts)
    if level == 0 then return end
    local val = ({0, 0.5, 0.7, 0.9})[level+1]
    for _, part in ipairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") and not isCharacterPart(part) then
            if part.Size.X >= 1 and part.Size.Y >= 1 and part.Size.Z >= 1 then
                local mat = part.Material
                if mat == Enum.Material.Plastic or mat == Enum.Material.SmoothPlastic or
                   mat == Enum.Material.Wood or mat == Enum.Material.WoodPlanks or
                   mat == Enum.Material.Brick or mat == Enum.Material.Concrete or
                   mat == Enum.Material.Metal or mat == Enum.Material.CorrodedMetal or
                   mat == Enum.Material.Marble or mat == Enum.Material.Slate or
                   mat == Enum.Material.Sandstone or mat == Enum.Material.Cobblestone then
                    pcall(function()
                        part.Transparency = val
                        table.insert(wallParts, part)
                    end)
                end
            end
        end
    end
end

