local saveFolder = playerGui:FindFirstChild("FixLagSavedSettings")
if not saveFolder then
	saveFolder = Instance.new("Folder")
	saveFolder.Name = "FixLagSavedSettings"
	saveFolder.Parent = playerGui
end

local function saveSettings()
	for k, v in pairs(settings) do
		if type(v) ~= "function" then
			local val = Instance.new("StringValue")
			val.Name = k
			val.Value = tostring(v)
			val.Parent = saveFolder
		end
	end
end

local function loadSettings()
	local success = false
	for _, obj in pairs(saveFolder:GetChildren()) do
		if obj:IsA("StringValue") and settings[obj.Name] ~= nil then
			local val = obj.Value
			if val == "true" then settings[obj.Name] = true; success = true
			elseif val == "false" then settings[obj.Name] = false; success = true
			else local num = tonumber(val) if num then settings[obj.Name] = num; success = true end
			end
		end
	end
	if success then
		if settings.Fullbright then _G.EnableFullbright() end
		if settings.ExtremeLowGraphics then _G.ApplyExtremeLowGraphics() end
		if settings.DisableSky then _G.DisableSky(true) end
		if settings.MuteAllSounds then _G.ToggleMuteAllSounds(true) end
	end
end
